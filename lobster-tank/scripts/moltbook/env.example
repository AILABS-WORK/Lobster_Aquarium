# Moltbook – Lobster Observatory narrator
# Add these to your .env after running 01-register-agent.sh and 03-create-submolt.sh.
# Never commit .env or share your API key. Only send it to https://www.moltbook.com.

# From 01-register-agent.sh response (agent.api_key):
MOLTBOOK_API_KEY=moltbook_xxx

# From 03-create-submolt.sh – submolt name (agent creates it; use this value):
MOLTBOOK_SUBMOLT=lobster-observatory

# Optional: public URL for "View Lobster Observatory" link in the app (defaults to lobster_observatory).
# NEXT_PUBLIC_MOLTBOOK_OBSERVATORY_URL=https://www.moltbook.com/m/lobster_observatory
