# Copy to .env and fill in. Never commit .env or real secrets.

# Required: Helius for Solana RPC (https://dashboard.helius.dev)
HELIUS_API_KEY=your_helius_api_key

# Required for DB: Postgres (e.g. Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Optional: Supabase project (if using Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for game: tank receives token transfers here
TANK_BANK_ADDRESS=your_solana_wallet_address
NEXT_PUBLIC_TANK_BANK_ADDRESS=your_solana_wallet_address

# Required: token mint (game token contract)
TOKEN_MINT=your_token_mint_address
NEXT_PUBLIC_TOKEN_MINT=your_token_mint_address

# Required for auth: set a random secret (e.g. openssl rand -hex 32)
AUTH_SECRET=your_random_auth_secret

# Optional: Moltbook integration
MOLTBOOK_API_KEY=
MOLTBOOK_SUBMOLT=
MOLTBOOK_POSTING_ENABLED=false
NEXT_PUBLIC_MOLTBOOK_OBSERVATORY_URL=

# Optional: AI narrator (OpenAI)
GPT_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: token gating (defaults in code)
TOKEN_OWNER_MIN=10000
TOKEN_CARETAKER_MIN=1000
TOKEN_FEED_MIN=100
REQUIRE_PASSWORD_TO_CLAIM=true

# Optional: cron / reset (set in production)
CRON_SECRET=

# Optional: dev bypass (do NOT set in production)
# DEV_OWNER_WALLET=
# NEXT_PUBLIC_DEV_OWNER_WALLET=

# Optional: UI flags (leave unset for production)
# NEXT_PUBLIC_SHOW_RESET_TANK=
# NEXT_PUBLIC_SHOW_MOLT_POST=
