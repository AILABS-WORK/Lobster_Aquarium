# Lobster Tank — copy to .env and fill in. Never commit .env.

# ─── Required for production ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
HELIUS_API_KEY=your_helius_api_key
TANK_BANK_ADDRESS=your_solana_wallet_address
TOKEN_MINT=your_spl_token_mint_address

# ─── Auth (required for login / set password and claim) ───────────────────
AUTH_SECRET=generate_a_long_random_string

# ─── Optional: Cron / internal API protection ───────────────────────────
CRON_SECRET=optional_secret_for_cron_and_tank_reset

# ─── Optional: Token / gating ─────────────────────────────────────────────
# PUM_TOKEN_MINT=optional_test_token_mint_for_feed_verify
# TOKEN_OWNER_MIN=10000
# TOKEN_CARETAKER_MIN=100
# TOKEN_FEED_MIN=100
# REQUIRE_PASSWORD_TO_CLAIM=true

# ─── Optional: Moltbook / AI narration ───────────────────────────────────
# MOLTBOOK_API_KEY=
# MOLTBOOK_SUBMOLT=
# MOLTBOOK_POSTING_ENABLED=true
# GPT_API_KEY=optional_for_ai_summaries
# OPENAI_MODEL=gpt-4o-mini

# ─── Public (exposed to browser; no secrets here) ────────────────────────
# NEXT_PUBLIC_TOKEN_MINT=same_as_TOKEN_MINT_if_you_want_ui_to_show_it
# NEXT_PUBLIC_TANK_BANK_ADDRESS=same_as_TANK_BANK_ADDRESS_for_instant_respawn_ui
# NEXT_PUBLIC_MOLTBOOK_OBSERVATORY_URL=https://www.moltbook.com/m/lobster-observatory

# ─── Production: leave UNSET ────────────────────────────────────────────
# DEV_OWNER_WALLET=           # Server-side dev bypass; do not set in production.
# NEXT_PUBLIC_DEV_OWNER_WALLET= # Exposed to client; do not set in production.
# NEXT_PUBLIC_SHOW_RESET_TANK=  # Set to "true" only for testing; must be unset/false in production.
