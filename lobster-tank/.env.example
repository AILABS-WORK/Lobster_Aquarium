# Database (Supabase: use Transaction pooler URL, port 6543)
DATABASE_URL=postgresql://user:password@host:6543/postgres?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/postgres?sslmode=require

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Helius (required for server-side Solana: feed verify, claim, balance checks)
HELIUS_API_KEY=your-helius-api-key

# Pump.fun token mint — set after launch. Used for gating (claim/feed/owner tier).
TOKEN_MINT=your_pumpfun_mint_address
NEXT_PUBLIC_TOKEN_MINT=your_pumpfun_mint_address

# Optional: second mint accepted for feed (e.g. test token)
# PUM_TOKEN_MINT=

# Tank bank wallet (receives feed transfers; instant respawn)
TANK_BANK_ADDRESS=your_tank_bank_wallet
NEXT_PUBLIC_TANK_BANK_ADDRESS=your_tank_bank_wallet

# Auth
AUTH_SECRET=generate-a-long-random-string

# Token thresholds
TOKEN_OWNER_MIN=100000
TOKEN_CARETAKER_MIN=1000
TOKEN_FEED_MIN=1000

# Optional: require password before claiming lobster
# REQUIRE_PASSWORD_TO_CLAIM=true

# Moltbook (optional)
# MOLTBOOK_API_KEY=
# MOLTBOOK_SUBMOLT=
# MOLTBOOK_POSTING_ENABLED=false
# NEXT_PUBLIC_MOLTBOOK_OBSERVATORY_URL=

# Cron (if using Vercel cron)
# CRON_SECRET=
