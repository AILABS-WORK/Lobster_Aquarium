# Lobster Tank — copy to .env and fill in. Never commit .env or real keys.
# Required for production:
HELIUS_API_KEY=
DATABASE_URL=
AUTH_SECRET=
TANK_BANK_ADDRESS=
TOKEN_MINT=

# Optional: Postgres (Prisma)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: Supabase (if using)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Optional: Moltbook (AI narration / posting)
# MOLTBOOK_API_KEY=
# MOLTBOOK_SUBMOLT=
# MOLTBOOK_POSTING_ENABLED=false

# Optional: Cron / internal API protection. Set in production.
# CRON_SECRET=

# Optional: Dev override wallet (bypass token balance for claiming). Leave unset in production.
# DEV_OWNER_WALLET=
# NEXT_PUBLIC_DEV_OWNER_WALLET=

# Optional: Token gating (defaults in code: owner 10000, caretaker 100, feed min 100)
# TOKEN_OWNER_MIN=10000
# TOKEN_CARETAKER_MIN=100
# TOKEN_FEED_MIN=100

# Optional: Require password before claiming
# REQUIRE_PASSWORD_TO_CLAIM=false

# Optional: Public (client) — only these are exposed to the browser
# NEXT_PUBLIC_SOLANA_RPC_URL=
# NEXT_PUBLIC_TOKEN_MINT=
# NEXT_PUBLIC_TANK_BANK_ADDRESS=
# NEXT_PUBLIC_MOLTBOOK_OBSERVATORY_URL=https://www.moltbook.com/m/lobster-observatory
# Do NOT set NEXT_PUBLIC_SHOW_RESET_TANK in production (testing only)
# NEXT_PUBLIC_SHOW_RESET_TANK=

# Optional: AI story (OpenAI). Server-side only.
# GPT_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional: Test token for feed verify (e.g. PUM)
# PUM_TOKEN_MINT=
